{
  "expo": {
    "name": "PricePulse",
    "slug": "pricepulse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-ybx.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/app-icon-ybx.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pricepulse.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon-ybx.png",
        "backgroundColor": "#000000"
      },
      "package": "com.pricepulse.app"
    },
    "web": {
      "favicon": "./assets/images/final_quest_240x240.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsWebPageWithMaxCount": 1
          },
          "androidIntentFilters": [
            "text/plain"
          ]
        }
      ]
    ],
    "scheme": "pricepulse",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://w99rpvg2jykqme8ytyqjerycckd6z729.app.specular.dev"
    }
  }
}